{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "noEmit": false,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": ["./**/*.ts", "../types/**/*.d.ts"],
  "exclude": ["node_modules", "../node_modules", "test/**/*", "**/*.test.ts", "**/*.spec.ts"]
}
